{
  "name": "opencode-statusline",
  "version": "2.0.3",
  "description": "OpenCode TUI plugin that displays project and session status in the Sidebar",
  "type": "module",
  "exports": {
    "./tui": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "config": {
        "enabled": true
      }
    }
  },
  "files": [
    "dist/",
    "scripts/"
  ],
  "scripts": {
    "build": "rm -rf dist && bun ./scripts/build.ts && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openspec",
    "statusline",
    "sidebar",
    "tui"
  ],
  "author": "perry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zpershuai/opencode-statusline.git"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.18.2",
    "@opentui/core": ">=0.4.3",
    "@opentui/solid": ">=0.4.3",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.18.2",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "@types/node": "^20.0.0",
    "solid-js": "^1.9.12",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
